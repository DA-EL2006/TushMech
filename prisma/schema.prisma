generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  MECHANIC
  ADMIN
  VENDOR
}

enum JobStatus {
  REQUESTED
  PENDING
  ASSIGNED
  EN_ROUTE
  DIAGNOSING
  QUOTING
  APPROVED
  IN_PROGRESS
  REPAIRING
  COMPLETED
  CANCELLED
}

enum DiagnosticStatus {
  DRAFT
  SUBMITTED
  QA_APPROVED
  REJECTED
}

enum ItemType {
  PART
  LABOR
  CONSUMABLE
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

enum PaymentMethod {
  PAYSTACK_CARD
  ALAT_BNPL
  CASH
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

// NextAuth Required Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Core Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  
  // Custom TushMech Fields
  role          Role      @default(CUSTOMER)
  phone         String?   @unique
  password_hash String?
  first_name    String?
  last_name     String?
  is_verified   Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  vehicles      Vehicle[]
  requests      Job[]     @relation("CustomerJobs")
  assignments   Job[]     @relation("MechanicJobs")
  
  wallet        Wallet?
  vendor_orders VendorOrder[] @relation("VendorOrders")
}

model Vehicle {
  id                String    @id @default(uuid())
  user_id           String
  make              String
  model             String
  year              Int
  license_plate     String
  vin               String?
  current_mileage   Int       @default(0)
  last_service_date DateTime?
  created_at        DateTime  @default(now())

  user              User      @relation(fields: [user_id], references: [id])
  jobs              Job[]
}

model Job {
  id               String    @id @default(uuid())
  customer_id      String
  mechanic_id      String?
  vehicle_id       String
  status           JobStatus @default(PENDING)
  reported_issue   String
  latitude         Float?
  longitude        Float?
  address          String?
  quoted_price     Float?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  customer         User      @relation("CustomerJobs", fields: [customer_id], references: [id])
  mechanic         User?     @relation("MechanicJobs", fields: [mechanic_id], references: [id])
  vehicle          Vehicle   @relation(fields: [vehicle_id], references: [id])
  
  diagnostic_report DiagnosticReport?
  invoice          Invoice?
  vendor_orders    VendorOrder[]
}

model DiagnosticReport {
  id             String           @id @default(uuid())
  job_id         String           @unique
  mechanic_notes String           @db.Text
  obd2_codes     String[]         
  photo_urls     String[]         
  status         DiagnosticStatus @default(DRAFT)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  job            Job              @relation(fields: [job_id], references: [id])
  estimate_items EstimateItem[]
}

model EstimateItem {
  id              String           @id @default(uuid())
  diagnostic_id   String
  type            ItemType
  description     String
  quantity        Int
  unit_price      Float
  total_price     Float
  created_at      DateTime         @default(now())

  diagnostic      DiagnosticReport @relation(fields: [diagnostic_id], references: [id])
}

model Invoice {
  id             String        @id @default(uuid())
  job_id         String        @unique
  subtotal       Float
  tax            Float
  total_amount   Float
  status         InvoiceStatus @default(UNPAID)
  payment_method PaymentMethod?
  alat_loan_id   String?
  bnpl_status    String?       
  issued_at      DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  job            Job           @relation(fields: [job_id], references: [id])
  transactions   Transaction[]
}

model Transaction {
  id         String            @id @default(uuid())
  invoice_id String
  amount     Float
  reference  String            @unique 
  status     TransactionStatus @default(PENDING)
  created_at DateTime          @default(now())

  invoice    Invoice           @relation(fields: [invoice_id], references: [id])
}

// Escrow & Financial Models
model Wallet {
  id               String   @id @default(uuid())
  user_id          String   @unique
  available_balance Float    @default(0)
  escrow_balance    Float    @default(0)
  updated_at       DateTime @updatedAt

  user             User     @relation(fields: [user_id], references: [id])
}

model VendorOrder {
  id             String   @id @default(uuid())
  vendor_id      String
  job_id         String
  part_name      String
  amount         Float
  quantity       Int      @default(1)
  status         String   @default("PENDING") // PENDING, SHIPPED, DELIVERED, DISPUTED
  escrow_status  String   @default("HELD")    // HELD, RELEASED, FROZEN
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  vendor         User     @relation("VendorOrders", fields: [vendor_id], references: [id])
  job            Job      @relation(fields: [job_id], references: [id])
}
